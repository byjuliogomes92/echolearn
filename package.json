{
  "name": "echolearn",
  "version": "0.0.1",
  "description": "Real-time captions for deaf students on EAD platforms",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky install",
    "type-check": "tsc --noEmit",
    "dev": "vite build --watch --mode development",
    "build": "vite build --mode production",
    "build:staging": "vite build --mode staging"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}